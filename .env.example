# Environment variables. Copy to .env (gitignored).
#
# This file is only needed if you enable the optional Supabase add-on.
# Without Supabase, agents run statelessly and this file can stay empty.

# --- Supabase (optional) ---
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
